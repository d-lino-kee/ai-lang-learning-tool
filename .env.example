# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── MySQL ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=linguablob
DB_PASSWORD=change_me_in_production
DB_NAME=linguablob
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ───
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=30d

# ─── Google Cloud ───
# Option 1: Path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option 2: Base64-encoded service account JSON (for Docker/CI)
# GCP_SA_KEY_BASE64=

# ─── Google Cloud Project ───
GOOGLE_CLOUD_PROJECT=your-project-id

# ─── CORS ───
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
