{
  "name": "linguablob-backend",
  "version": "0.1.0",
  "description": "LinguaBlob — Speech-to-Speech language learning backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:down": "tsx src/scripts/migrate.ts --down",
    "seed": "tsx src/scripts/seed.ts",
    "validate-gcp": "tsx src/scripts/validate-gcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/speech": "^6.7.0",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google-cloud/translate": "^8.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "axe-playwright": "^2.0.3",
    "eslint": "^9.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
