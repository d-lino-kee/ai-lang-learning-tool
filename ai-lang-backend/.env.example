# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Google Cloud (STT + TTS) ──────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global

# ── Gemini AI ─────────────────────────────────────────────────────────────────
